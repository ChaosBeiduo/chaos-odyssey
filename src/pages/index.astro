---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogPost from "../components/BlogPost.astro";

const allPosts = Object.values(
	import.meta.glob('./posts/*.{md,mdx}', { eager: true })
);
const sortedPosts = allPosts.sort((a: any, b: any) => {
	const dateA = a.frontmatter.pubDate ? new Date(a.frontmatter.pubDate).valueOf() : 0;
	const dateB = b.frontmatter.pubDate ? new Date(b.frontmatter.pubDate).valueOf() : 0;
	return dateB - dateA;
});
---

<BaseLayout pageTitle={'Blog'}>
	<style lang="scss">
		.chaos-mail-inbox {
			grid-column: 1 / 25;
			padding-top: 36px;
			max-width: 100%;

			@media (max-width: 768px) {
				padding-top: 20px;
			}
		}

		.chaos-mail-inbox-header {
			margin-bottom: 24px;
			padding-bottom: 12px;
			border-bottom: 2px solid var(--gray-border);

			h1 {
				margin: 0;
				font-size: 1.5rem;
				font-weight: 600;
				color: var(--gray);
			}

			@media (max-width: 768px) {
				margin-bottom: 16px;
				padding-bottom: 8px;

				h1 {
					font-size: 1.25rem;
				}
			}
		}

		.chaos-mail-list {
			display: flex;
			flex-direction: column;
			background: white;
			border: 1px solid var(--gray-border);
			border-radius: 8px;
			overflow: hidden;
			box-shadow: 0 1px 3px color-mix(in oklch, var(--gray) 8%, transparent);

			@media (max-width: 768px) {
				border-radius: 0;
				border-left: none;
				border-right: none;
			}
		}

		.chaos-mail-empty {
			padding: 48px 20px;
			text-align: center;
			color: var(--gray);
			opacity: 0.6;
			font-size: 0.9375rem;
		}
	</style>

	<div class="chaos-mail-inbox">
		<header class="chaos-mail-inbox-header">
			<h1>Blog</h1>
		</header>

		{sortedPosts.length > 0 ? (
			<div class="chaos-mail-list" role="list">
				{sortedPosts.map((post: any) => (
					<BlogPost post={post} />
				))}
			</div>
		) : (
			<div class="chaos-mail-empty">
				No posts yet. Check back soon!
			</div>
		)}
	</div>
</BaseLayout>
