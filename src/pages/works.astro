---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkCard from "../components/WorkCard.astro";

const websiteWorks = [
    {
        title: "Pachinko Sphere",
        description: "A 3D lottery drawing application built with Astro and Three.js. Features a beautiful \"sphere of names\" that spins and selects winners with smooth animations.",
        image: "/images/Projects/pachinko-sphere.png",
        url: "https://pachinko-sphere.vercel.app/",
        technologies: ["Astro", "TypeScript", "Three.js"]
    },
];

const generateGallery = () => {
    const modules = import.meta.glob('../../public/images/Gallery/*.{jpeg,jpg,png,webp}', { eager: true });
    
    const rawPhotos = Object.keys(modules).map(path => {
        const fullFileName = path.split('/').pop().split('.')[0];
        const parts = fullFileName.split('_');
        const datePart = parts[0] || '';
        const titlePart = parts[1] || 'Untitled';
        return {
            src: path.replace('./public', ''),
            date: datePart.replace(/-/g, '.'),
            desc: titlePart.charAt(0).toUpperCase() + titlePart.slice(1)
        };
    });

    const groups: Record<string, any[]> = {};
    rawPhotos.forEach(photo => {
        if (!groups[photo.date]) groups[photo.date] = [];
        groups[photo.date].push(photo);
    });

    return Object.entries(groups)
        .map(([date, photos]) => ({
            date,
            photos,
            cover: photos[0],
            count: photos.length
        }))
        .sort((a, b) => new Date(b.date.replace(/\./g, '-')).getTime() - new Date(a.date.replace(/\./g, '-')).getTime());
};

const photoGroups = generateGallery();
---

<BaseLayout pageTitle={'Work'}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400..700&family=VT323&display=swap" rel="stylesheet">

    <div class="work-container">
        <section class="website-portfolio">
            <div class="section-header">
                <h2 class="section-title">Projects</h2>
            </div>
            <div class="website-grid">
                {websiteWorks.map(work => (
                    <WorkCard {...work} />
                ))}
            </div>
        </section>

        <section class="photo-portfolio">
            <div class="section-header">
                <h2 class="section-title">Photography Gallery</h2>
            </div>
            <div class="polaroid-gallery">
                {photoGroups.map((group, index) => (
                    <div 
                        class="polaroid-item photo-trigger" 
                        style={`--rotation: ${(index % 3 - 1) * (Math.random() * 5 + 2)}deg;`}
                        data-photos={JSON.stringify(group.photos)}
                    >
                        <div class="polaroid-inner">
                            <div class="polaroid-stack-effect"></div>
                            <img src={group.cover.src} alt={group.date} loading="lazy" />
                            {group.count > 1 && <div class="polaroid-count">×{group.count}</div>}
                            <div class="polaroid-caption grid text-end">
                                <span>{group.date}</span>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>
    </div>

    <!-- Light Black Resident Evil Style Modal -->
    <div id="photo-modal" class="re-modal">
        <div class="re-modal-overlay"></div>
        <div class="re-modal-content">
            <div class="re-header-group">
                <div id="re-date-header" class="re-date-header"></div>
                <div class="re-header-divider"></div>
            </div>
            
            <div class="re-viewer">
                <button class="re-nav prev" id="re-prev" aria-label="Previous"><i class="fa-solid fa-chevron-left"></i></button>
                <div class="re-image-wrapper">
                    <img id="modal-img" src="" alt="Examine" />
                </div>
                <button class="re-nav next" id="re-next" aria-label="Next"><i class="fa-solid fa-chevron-right"></i></button>
            </div>

            <div class="re-description-box">
                <div id="typewriter-text" class="re-text"></div>
                <div class="re-meta">
                    <span id="re-counter" class="re-counter"></span>
                    <span class="re-prompt">ESC to close / ARROWS to navigate</span>
                </div>
            </div>
        </div>
    </div>
</BaseLayout>

<script>
    const modal = document.getElementById('photo-modal');
    const modalImg = document.getElementById('modal-img') as HTMLImageElement;
    const typewriterText = document.getElementById('typewriter-text');
    const reCounter = document.getElementById('re-counter');
    const reDateHeader = document.getElementById('re-date-header');
    const prevBtn = document.getElementById('re-prev');
    const nextBtn = document.getElementById('re-next');
    const triggers = document.querySelectorAll('.photo-trigger');
    
    let currentPhotos: any[] = [];
    let currentIndex = 0;
    let typeInterval: any = null;

    function typeWriter(text: string) {
        if (!typewriterText) return;
        typewriterText.textContent = '';
        let i = 0;
        clearInterval(typeInterval);
        typeInterval = setInterval(() => {
            if (i < text.length) {
                typewriterText.textContent += text.charAt(i);
                i++;
            } else {
                clearInterval(typeInterval);
            }
        }, 25);
    }

    function updateModalContent() {
        if (!modalImg || !reCounter || !reDateHeader || currentPhotos.length === 0) return;
        
        const photo = currentPhotos[currentIndex];
        modalImg.style.opacity = '0';
        
        setTimeout(() => {
            modalImg.src = photo.src;
            modalImg.style.opacity = '1';
            
            // Date above photo
            reDateHeader.textContent = `${photo.date}`;
            
            // Text below photo
            const fullText = `"${photo.desc}"... A fragment of memory preserved in time.`;
            typeWriter(fullText);
            
            reCounter.textContent = `${currentIndex + 1} / ${currentPhotos.length}`;
            
            if (prevBtn) prevBtn.style.visibility = currentPhotos.length > 1 ? 'visible' : 'hidden';
            if (nextBtn) nextBtn.style.visibility = currentPhotos.length > 1 ? 'visible' : 'hidden';
        }, 150);
    }

    triggers.forEach(trigger => {
        trigger.addEventListener('click', () => {
            const photosData = trigger.getAttribute('data-photos');
            if (photosData && modal) {
                currentPhotos = JSON.parse(photosData);
                currentIndex = 0;
                modal.classList.add('active');
                updateModalContent();
            }
        });
    });

    function nextPhoto() {
        if (currentPhotos.length <= 1) return;
        currentIndex = (currentIndex + 1) % currentPhotos.length;
        updateModalContent();
    }

    function prevPhoto() {
        if (currentPhotos.length <= 1) return;
        currentIndex = (currentIndex - 1 + currentPhotos.length) % currentPhotos.length;
        updateModalContent();
    }

    prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); prevPhoto(); });
    nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); nextPhoto(); });

    function closeModal() {
        if (modal) {
            modal.classList.remove('active');
            clearInterval(typeInterval);
            currentPhotos = [];
        }
    }

    modal?.addEventListener('click', (e) => {
        if (e.target === modal || (e.target as HTMLElement).classList.contains('re-modal-overlay')) {
            closeModal();
        }
    });

    window.addEventListener('keydown', (e) => {
        if (!modal?.classList.contains('active')) return;
        if (e.key === 'Escape') closeModal();
        if (e.key === 'ArrowRight') nextPhoto();
        if (e.key === 'ArrowLeft') prevPhoto();
    });
</script>

<style lang="scss">
    @use '../styles/_mixins.scss' as *;

    .work-container {
        display: flex;
        flex-direction: column;
        gap: 80px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
        margin-bottom: 32px;
        padding-bottom: 8px;
        width: 100%;
        border-bottom: 2px solid var(--secondary);
    }

    .section-title {
        font-size: 1.5rem;
        color: var(--primary);
        margin: 0;
    }

    .website-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 32px;
    }

    .polaroid-gallery {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 48px;
        padding: 20px 0;
        justify-items: center;
    }

    .polaroid-item {
        transform: rotate(var(--rotation));
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        
        &:hover {
            transform: rotate(0deg) scale(1.08) translateY(-10px);
            z-index: 10;
        }
    }

    .polaroid-inner {
        background: #fdfdfd;
        padding: 8px;
        padding-bottom: 16px;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
        width: 260px;
        position: relative;

        img {
            width: 100%;
            aspect-ratio: 1 / 1;
            object-fit: cover;
            border: 1px solid #eee;
            margin-bottom: 12px;
            background: #f0f0f0;
        }
    }

    .polaroid-count {
        position: absolute;
        top: 16px;
        right: 16px;
        background: rgba(0,0,0,0.7);
        color: white;
        padding: 2px 8px;
        font-family: 'VT323', monospace;
        font-size: 1rem;
        border-radius: 2px;
        z-index: 2;
    }

    .polaroid-stack-effect {
        position: absolute;
        inset: 0;
        background: white;
        border: 1px solid #eee;
        z-index: -1;
        transform: translate(4px, 4px) rotate(2deg);
        box-shadow: 2px 2px 5px rgba(0,0,0,0.05);

        &::after {
            content: '';
            position: absolute;
            inset: 0;
            background: white;
            border: 1px solid #eee;
            transform: translate(4px, 4px) rotate(-4deg);
        }
    }

    .polaroid-caption {
        padding: 0 4px;
        span {
            font-family: 'Caveat', cursive;
            font-size: 1.6rem;
            color: #333;
            line-height: 1;
        }
    }

    /* Light Black RE Modal Style */
    .re-modal {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: none;
        align-items: center;
        justify-content: center;

        &.active { display: flex; }

        &-overlay {
            position: absolute;
            inset: 0;
            background: rgba(18, 18, 18, 0.85); // Light Black Translucent
            backdrop-filter: blur(12px);
        }

        &-content {
            position: relative;
            z-index: 1001;
            width: 95%;
            max-width: 800px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }
    }

    .re-header-group {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

    .re-date-header {
        font-family: 'VT323', monospace;
        font-size: 1.8rem;
        color: #eee;
        text-align: center;
        letter-spacing: 5px;
        opacity: 0.9;
    }

    .re-header-divider {
        width: 60%;
        height: 1px;
        background: linear-gradient(to right, transparent, rgba(238, 238, 238, 0.5), transparent);
    }

    .re-viewer {
        display: flex;
        align-items: center;
        gap: 15px;
        width: 100%;
    }

    .re-nav {
        background: none;
        border: none;
        color: #fff;
        font-size: 2rem;
        cursor: pointer;
        transition: all 0.2s ease;
        padding: 10px;
        opacity: 0.3;

        &:hover {
            opacity: 1;
            transform: scale(1.2);
            text-shadow: 0 0 10px rgba(255,255,255,0.5);
        }
    }

    .re-image-wrapper {
        flex: 1;
        background: #000;
        box-shadow: 0 0 40px rgba(0,0,0,0.6);
        display: flex;
        justify-content: center;
        align-items: center;
        border: 1px solid #333;

        img {
            max-width: 100%;
            max-height: 60vh;
            object-fit: contain;
            transition: opacity 0.3s ease;
        }
    }

    .re-description-box {
        background: rgba(0, 0, 0, 0.6);
        border: 1px solid #333;
        padding: 24px;
        min-height: 120px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        box-shadow: inset 0 0 20px rgba(0,0,0,0.4);
    }

    .re-text {
        color: #fff;
        font-family: 'VT323', monospace;
        font-size: 1.6rem;
        line-height: 1.4;
        text-align: center;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
    }

    .re-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 15px;
        padding-top: 10px;
        border-top: 1px solid #222;
    }

    .re-counter {
        color: #ddd;
        font-family: 'VT323', monospace;
        font-size: 1.4rem;
        letter-spacing: 2px;
    }

    .re-prompt {
        color: #666;
        font-family: 'VT323', monospace;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    @media (max-width: 768px) {
        .re-nav { font-size: 1.5rem; }
        .re-text { font-size: 1.3rem; }
        .re-date-header { font-size: 1.4rem; }
        .re-header-divider { width: 80%; }
    }
</style>
