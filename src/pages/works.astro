---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkCard from "../components/WorkCard.astro";
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const websiteWorks = [
    {
        title: "Pachinko Sphere",
        description: "A 3D lottery drawing application built with Astro and Three.js. Features a beautiful \"sphere of names\" that spins and selects winners with smooth animations.",
        image: "/images/Projects/pachinko-sphere.png",
        url: "https://pachinko-sphere.vercel.app/",
        repoUrl: "https://github.com/ChaosBeiduo/pachinko-sphere",
        technologies: ["Astro", "TypeScript", "Three.js"]
    },
    {
        title: "Spinning Wheel",
        description: "A Vue-based spinning wheel demo built with Canvas API for randomized gift selection.",
        image: "/images/Projects/spinning-wheel.png",
        url: "https://spinning-wheel-nine.vercel.app/",
        repoUrl: "https://github.com/ChaosBeiduo/Spinning-Wheel",
        technologies: ["Vue", "Canvas API"]
    }
];

const generateGallery = async () => {
    console.log(">>> [Gallery Debug] Starting gallery generation...");
    // 1. 扫描 assets 目录
    const modules = import.meta.glob<{ default: ImageMetadata }>('/src/assets/gallery/**/*.{jpeg,jpg,png,webp,JPEG,JPG}', { eager: true });
    console.log(`>>> [Gallery Debug] Found ${Object.keys(modules).length} image modules.`);
    
    // 2. 获取元数据覆盖
    const metadataEntries = await getCollection('gallery-metadata');
    console.log(`>>> [Gallery Debug] Metadata entries found: ${metadataEntries.length}`);

    const rawPhotos = await Promise.all(Object.entries(modules).map(async ([path, module]) => {
        // 提取 ID: "2026-02-17/01"
        const id = path
            .replace('/src/assets/gallery/', '')
            .replace(/\.[^/.]+$/, '');

        const [datePart] = id.split('/');
        // 直接从 collection 数组中匹配对应 ID 的项
        const photoMetadata = metadataEntries.find(m => m.id === id)?.data || {};

        console.log(`>>> [Gallery Debug] Processing ID: ${id}, hasOverride: ${!!photoMetadata.title}`);

        // 为每张照片生成 thumb 和 large 版本，提升大图宽度到 1600px 并增加清晰度
        const thumb = await getImage({ src: module.default, width: 400, format: 'webp', quality: 80 });
        const large = await getImage({ src: module.default, width: 1600, format: 'webp', quality: 90 });

        return {
            src: module.default.src,
            thumb: thumb.src,
            large: large.src,
            date: datePart.replace(/-/g, '.'),
            title: photoMetadata.title,
            description: photoMetadata.description || ''
        };
    }));

    const groups: Record<string, any[]> = {};
    rawPhotos.forEach(photo => {
        if (!groups[photo.date]) groups[photo.date] = [];
        groups[photo.date].push(photo);
    });

    return Object.entries(groups)
        .map(([date, photos]) => ({
            date,
            photos,
            cover: photos[0],
            count: photos.length
        }))
        // 按 ID (日期) 倒序排列
        .sort((a, b) => b.date.localeCompare(a.date));
};

const photoGroups = await generateGallery();
---

<BaseLayout pageTitle={'Work'}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400..700&family=VT323&display=swap" rel="stylesheet">

    <div class="flex flex-col gap-20">
        <section>
            <div class="flex justify-between items-center flex-wrap gap-4 mb-8 pb-2 w-full border-b-2 border-[var(--gray-border)]">
                <h2 class="text-2xl text-[var(--primary)] m-0">Projects</h2>
            </div>
            <div class="grid grid-cols-[repeat(auto-fill,minmax(320px,1fr))] gap-8">
                {websiteWorks.map(work => (
                    <WorkCard {...work} />
                ))}
            </div>
        </section>

        <section>
            <div class="flex justify-between items-center flex-wrap gap-4 mb-8 pb-2 w-full border-b-2 border-[var(--gray-border)]">
                <h2 class="text-2xl text-[var(--primary)] m-0">Gallery</h2>
            </div>
            <div class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-y-4 py-5 justify-items-center">
                {photoGroups.map((group, index) => (
                    <div 
                        class="photo-trigger cursor-pointer transition-all duration-300 ease-[cubic-bezier(0.175,0.885,0.32,1.275)] hover:rotate-0 hover:scale-[1.08] hover:-translate-y-2.5 hover:z-10"
                        style={`transform: rotate(${(index % 3 - 1) * (Math.random() * 5 + 2)}deg);`}
                        data-photos={JSON.stringify(group.photos)}
                    >
                        <div class="bg-[#fdfdfd] p-2 pb-4 shadow-[0_10px_20px_rgba(0,0,0,0.1)] w-[260px] relative">
                            {group.count > 1 && (
                                <div class="absolute inset-0 bg-white border border-[#eee] -z-10 translate-x-1 translate-y-1 rotate-2 shadow-[2px_2px_5px_rgba(0,0,0,0.05)] after:content-[''] after:absolute after:inset-0 after:bg-white after:border after:border-[#eee] after:translate-x-1 after:translate-y-1 after:-rotate-4"></div>
                            )}
                            <img src={group.cover.thumb} alt={group.date} loading="lazy" class="w-full aspect-square object-cover border border-[#eee] mb-3 bg-[#f0f0f0]" />
                            {group.count > 1 && <div class="absolute top-4 right-4 bg-black/70 text-white px-2 py-0.5 text-base rounded-[2px] z-[2]">×{group.count}</div>}
                            <div class="px-1 grid text-end">
                                <span class="font-caveat text-[1.6rem] text-[#333] leading-none">{group.date}</span>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>
    </div>

    <!-- Light Black Resident Evil Style Modal -->
    <div id="photo-modal" class="fixed inset-0 z-[1000] flex items-center justify-center opacity-0 pointer-events-none invisible transition-all duration-300 ease-out [&.active]:opacity-100 [&.active]:pointer-events-auto [&.active]:visible">
        <div class="absolute inset-0 bg-[#121212]/85 backdrop-blur-xl re-modal-overlay"></div>
        <div class="relative z-[1001] w-[95%] max-w-[800px] flex flex-col gap-5 transition-transform duration-300 scale-95 [.active_&]:scale-100">
            <div class="w-full flex flex-col items-center gap-2">
                <div id="re-date-header" class="text-[#eee] font-extralight text-center tracking-[5px] opacity-90"></div>
                <div class="w-[80%] md:w-[60%] h-px bg-gradient-to-r from-transparent via-[#eee]/50 to-transparent"></div>
            </div>
            
            <div class="flex items-center gap-[15px] w-full">
                <button class="bg-none border-none text-white text-[1.5rem] md:text-[2rem] cursor-pointer transition-all duration-200 p-2.5 opacity-30 hover:opacity-100 hover:drop-shadow-[0_0_10px_rgba(255,255,255,0.5)]" id="re-prev" aria-label="Previous"><i class="fa-solid fa-chevron-left"></i></button>
                <div class="flex-1 bg-black shadow-[0_0_40px_rgba(0,0,0,0.6)] flex justify-center items-center border border-[#333] relative overflow-hidden group aspect-[3/2] w-full">
                    <img id="modal-img" src="" alt="Examine" loading="lazy" class="max-w-full max-h-full object-contain transition-opacity duration-500 opacity-0" />

                    <!-- Cinematic Overlay -->
                    <div class="absolute bottom-0 left-0 w-full">
                        <div id="typewriter-text" class="m-auto mb-2 px-2 w-fit text-white tracking-wider text-xl text-center [text-shadow:-1px_-1px_0_#000,1px_-1px_0_#000,-1px_1px_0_#000,1px_1px_0_#000] min-h-[3.2rem] flex items-center justify-center"></div>
                    </div>
                </div>
                <button class="bg-none border-none text-white text-[1.5rem] md:text-[2rem] cursor-pointer transition-all duration-200 p-2.5 opacity-30 hover:opacity-100 hover:drop-shadow-[0_0_10px_rgba(255,255,255,0.5)]" id="re-next" aria-label="Next"><i class="fa-solid fa-chevron-right"></i></button>
            </div>

            <div class="flex justify-center items-center mt-2 pt-2 border-t border-white/5">
                <span id="re-counter" class="text-[#ddd] tracking-[2px] font-extralight"></span>
            </div>
        </div>
    </div>
</BaseLayout>

<script>
    const modal = document.getElementById('photo-modal');
    const modalImg = document.getElementById('modal-img') as HTMLImageElement;
    const typewriterText = document.getElementById('typewriter-text');
    const reCounter = document.getElementById('re-counter');
    const reDateHeader = document.getElementById('re-date-header');
    const prevBtn = document.getElementById('re-prev');
    const nextBtn = document.getElementById('re-next');
    const triggers = document.querySelectorAll('.photo-trigger');
    
    let currentPhotos: any[] = [];
    let currentIndex = 0;
    let typeInterval: any = null;

    function typeWriter(text: string) {
        if (!typewriterText) return;
        typewriterText.textContent = '';
        let i = 0;
        clearInterval(typeInterval);
        typeInterval = setInterval(() => {
            if (i < text.length) {
                typewriterText.textContent += text.charAt(i);
                i++;
            } else {
                clearInterval(typeInterval);
            }
        }, 25);
    }

    function updateModalContent() {
        if (!modalImg || !reCounter || !reDateHeader || currentPhotos.length === 0) return;
        
        const photo = currentPhotos[currentIndex];
        
        // 1. 先启动淡出动画到黑色背景
        modalImg.style.opacity = '0';
        
        // 2. 等待淡出动画进行一半后切换 src，这样过渡更自然
        setTimeout(() => {
            modalImg.src = '';
            
            // 预设加载回调
            modalImg.onload = () => {
                // 确保在设置透明度前，浏览器已经知道它是 0 了
                requestAnimationFrame(() => {
                    modalImg.style.opacity = '1';
                });
            };

            modalImg.src = photo.large;
            
            // 更新文字信息
            reDateHeader.textContent = `${photo.date}`;
            const fullText = photo.description || (photo.title ? `"${photo.title}"... Surely that is enough.` : `Nothing was entered for this photo.`);
            typeWriter(fullText);
            
            reCounter.textContent = `${currentIndex + 1} / ${currentPhotos.length}`;
            if (prevBtn) prevBtn.style.visibility = currentPhotos.length > 1 ? 'visible' : 'hidden';
            if (nextBtn) nextBtn.style.visibility = currentPhotos.length > 1 ? 'visible' : 'hidden';
        }, 200); 
    }

    triggers.forEach(trigger => {
        trigger.addEventListener('click', () => {
            const photosData = trigger.getAttribute('data-photos');
            if (photosData && modal) {
                currentPhotos = JSON.parse(photosData);
                currentIndex = 0;
                modal.classList.add('active');
                
                // 打开弹窗时，先确保图片是空的且透明的
                if (modalImg) {
                    modalImg.src = '';
                    modalImg.style.opacity = '0';
                }
                
                // 稍微延迟一点点再加载内容，确保弹窗打开动画不卡顿
                setTimeout(updateModalContent, 50);
            }
        });
    });

    function nextPhoto() {
        if (currentPhotos.length <= 1) return;
        currentIndex = (currentIndex + 1) % currentPhotos.length;
        updateModalContent();
    }

    function prevPhoto() {
        if (currentPhotos.length <= 1) return;
        currentIndex = (currentIndex - 1 + currentPhotos.length) % currentPhotos.length;
        updateModalContent();
    }

    prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); prevPhoto(); });
    nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); nextPhoto(); });

    function closeModal() {
        if (modal) {
            modal.classList.remove('active');
            clearInterval(typeInterval);
            
            // 关键：等待弹窗关闭动画（300ms）结束后再彻底清空状态
            setTimeout(() => {
                currentPhotos = [];
                if (modalImg) {
                    modalImg.src = '';
                    modalImg.style.opacity = '0';
                    modalImg.onload = null;
                }
            }, 300);
        }
    }

    modal?.addEventListener('click', (e) => {
        if (e.target === modal || (e.target as HTMLElement).classList.contains('re-modal-overlay')) {
            closeModal();
        }
    });

    window.addEventListener('keydown', (e) => {
        if (!modal?.classList.contains('active')) return;
        if (e.key === 'Escape') closeModal();
        if (e.key === 'ArrowRight') nextPhoto();
        if (e.key === 'ArrowLeft') prevPhoto();
    });
</script>
