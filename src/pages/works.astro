---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkCard from "../components/WorkCard.astro";

const websiteWorks = [
    {
        title: "Pachinko Sphere",
        description: "A 3D lottery drawing application built with Astro and Three.js. Features a beautiful \"sphere of names\" that spins and selects winners with smooth animations.",
        image: "/images/Projects/pachinko-sphere.png",
        url: "https://pachinko-sphere.vercel.app/",
        technologies: ["Astro", "TypeScript", "Three.js"]
    },
];

const generateGallery = () => {
    // 扫描目录
    const modules = import.meta.glob('../../public/images/Gallery/*.{jpeg,jpg,png,webp}', { eager: true });

    return Object.keys(modules).map(path => {
        // 提取带后缀的文件名，例如 "2026-02-20_outskirt"
        const fullFileName = path.split('/').pop().split('.')[0];

        // 使用下划线拆分
        // [0] 是 2026-02-20, [1] 是 outskirt
        const parts = fullFileName.split('_');
        const datePart = parts[0] || '';
        const titlePart = parts[1] || 'Untitled'; // 如果没有下划线，显示 Untitled

        return {
            // 浏览器访问路径
            src: path.replace('./public', ''),
            // 转换为 2026.02.20 展示格式
            date: datePart.replace(/-/g, '.'),
            // 首字母大写处理 (outskirt -> Outskirt)
            desc: titlePart.charAt(0).toUpperCase() + titlePart.slice(1)
        };
    });
};

// 排序逻辑保持不变
const photoWorks = generateGallery().sort((a, b) => {
    return new Date(b.date).getTime() - new Date(a.date).getTime();
});
---

<BaseLayout pageTitle={'Work'}>
    <!-- Google Font for Hand-written style and Monospace -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400..700&family=VT323&display=swap" rel="stylesheet">

    <div class="work-container">
        <!--  1. 作品集  -->
        <section class="website-portfolio">
            <div class="section-header">
                <h2 class="section-title">Projects</h2>
            </div>
            <div class="website-grid">
                {websiteWorks.map(work => (
                    <WorkCard {...work} />
                ))}
            </div>
        </section>

        <!--  2. 摄影作品集  -->
        <section class="photo-portfolio">
            <div class="section-header">
                <h2 class="section-title">Photography Gallery</h2>
            </div>
            <div class="polaroid-gallery">
                {photoWorks.map((photo, index) => (
                    <div 
                        class="polaroid-item photo-trigger" 
                        style={`--rotation: ${(index % 3 - 1) * (Math.random() * 5 + 2)}deg;`}
                        data-src={photo.src}
                        data-desc={photo.desc}
                        data-date={photo.date}
                    >
                        <div class="polaroid-inner">
                            <img src={photo.src} alt={photo.desc} loading="lazy" />
                            <div class="polaroid-caption grid text-end">
                                {photo.desc && <span>{photo.desc}</span>}
                                <span>{photo.date}</span>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>
    </div>

    <!-- Resident Evil Style Modal -->
    <div id="photo-modal" class="re-modal">
        <div class="re-modal-overlay"></div>
        <div class="re-modal-content">
            <div class="re-image-wrapper">
                <img id="modal-img" src="" alt="Examine" />
            </div>
            <div class="re-description-box">
                <div id="typewriter-text" class="re-text"></div>
                <div class="re-prompt">Press ESC to return...</div>
            </div>
        </div>
    </div>
</BaseLayout>

<script>
    const modal = document.getElementById('photo-modal');
    const modalImg = document.getElementById('modal-img') as HTMLImageElement;
    const typewriterText = document.getElementById('typewriter-text');
    const triggers = document.querySelectorAll('.photo-trigger');
    let typeInterval: any = null;

    function typeWriter(text: string) {
        if (!typewriterText) return;
        typewriterText.textContent = '';
        let i = 0;
        clearInterval(typeInterval);
        
        typeInterval = setInterval(() => {
            if (i < text.length) {
                typewriterText.textContent += text.charAt(i);
                i++;
            } else {
                clearInterval(typeInterval);
            }
        }, 50); // Typing speed
    }

    triggers.forEach(trigger => {
        trigger.addEventListener('click', () => {
            const src = trigger.getAttribute('data-src');
            const desc = trigger.getAttribute('data-desc');
            const date = trigger.getAttribute('data-date');
            
            if (modal && modalImg && src) {
                modalImg.src = src;
                modal.classList.add('active');
                const fullText = `It's a photograph. "${desc}"... Recorded on ${date}.`;
                typeWriter(fullText);
            }
        });
    });

    function closeModal() {
        if (modal) {
            modal.classList.remove('active');
            clearInterval(typeInterval);
        }
    }

    modal?.addEventListener('click', (e) => {
        if (e.target === modal || (e.target as HTMLElement).classList.contains('re-modal-overlay')) {
            closeModal();
        }
    });

    window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            closeModal();
        }
    });
</script>

<style lang="scss">
    @use '../styles/_mixins.scss' as *;

    .work-container {
        display: flex;
        flex-direction: column;
        gap: 80px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
        margin-bottom: 32px;
        padding-bottom: 8px;
        width: 100%;
        border-bottom: 2px solid var(--secondary);
    }

    .section-title {
        font-size: 1.5rem;
        color: var(--primary);
        margin: 0;
    }

    .website-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 32px;
    }

    /* Polaroid Styles */
    .polaroid-gallery {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 32px;
        padding: 20px 0;
        justify-items: center;
        width: 100%;
    }

    .polaroid-item {
        transform: rotate(var(--rotation));
        transition: transform 0.3s ease, z-index 0s;
        cursor: pointer;
        
        &:hover {
            transform: rotate(0deg) scale(1.05);
            z-index: 10;
        }
    }

    .polaroid-inner {
        background: #fdfdfd;
        padding: 6px;
        padding-bottom: 12px;
        box-shadow: 0 8px 12px rgba(0, 0, 0, 0.1);
        width: 280px;
        position: relative;

        img {
            width: 100%;
            aspect-ratio: 1 / 1;
            object-fit: cover;
            border: 1px solid #f0f0f0;
            margin-bottom: 12px;
        }
    }

    .polaroid-caption {
        padding: 0 4px;
        transform: rotate(-2deg);

      span{
        font-family: 'Caveat', cursive;
        font-size: 1.5rem;
        color: #333;
        line-height: 1.2;
      }
    }

    /* Resident Evil Modal Style */
    .re-modal {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: none;
        align-items: center;
        justify-content: center;
        overflow: hidden;

        &.active {
            display: flex;
        }

        &-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(5px);
        }

        &-content {
            position: relative;
            z-index: 1001;
            width: 90%;
            max-width: 800px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 24px;
        }
    }

    .re-image-wrapper {
        width: 100%;
        max-height: 60vh;
        display: flex;
        justify-content: center;
        border: 2px solid #333;
        background: #000;
        box-shadow: 0 0 30px rgba(0,0,0,0.5);

        img {
            max-width: 100%;
            max-height: 60vh;
            object-fit: contain;
        }
    }

    .re-description-box {
        width: 100%;
        background: rgba(0, 0, 0, 0.85);
        border: 1px solid #444;
        padding: 20px;
        min-height: 100px;
        position: relative;
        box-shadow: inset 0 0 15px rgba(255,255,255,0.05);

        &::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, #888, transparent);
        }
    }

    .re-text {
        color: #eee;
        font-family: 'VT323', monospace;
        font-size: 1.5rem;
        line-height: 1.4;
        text-shadow: 2px 2px 0 #000;
        margin-bottom: 10px;
    }

    .re-prompt {
        color: #666;
        font-family: 'VT323', monospace;
        font-size: 1rem;
        text-align: right;
        margin-top: 10px;
        animation: blink 1.5s infinite;
    }

    @keyframes blink {
        0%, 100% { opacity: 0.3; }
        50% { opacity: 0.8; }
    }

    @media (max-width: 768px) {
        .website-grid {
            grid-template-columns: 1fr;
        }

        .polaroid-gallery {
            grid-template-columns: 1fr;
            gap: 40px;
        }

        .re-modal-content {
            width: 95%;
        }

        .re-text {
            font-size: 1.2rem;
        }
    }
</style>
