---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkCard from "../components/WorkCard.astro";

const websiteWorks = [
    {
        title: "Pachinko Sphere",
        description: "A 3D lottery drawing application built with Astro and Three.js. Features a beautiful \"sphere of names\" that spins and selects winners with smooth animations.",
        image: "/images/pagination-amazon.png",
        url: "https://pachinko-sphere.vercel.app/",
        technologies: ["Astro", "TypeScript", "Three.js"]
    },
];

const photoWorks = [
    { src: "https://picsum.photos/id/10/400/600", alt: "Nature" },
    { src: "https://picsum.photos/id/11/400/600", alt: "Nature" },
    { src: "https://picsum.photos/id/12/400/600", alt: "Nature" },
    { src: "https://picsum.photos/id/13/400/600", alt: "Nature" },
    { src: "https://picsum.photos/id/14/400/600", alt: "Nature" },
    { src: "https://picsum.photos/id/15/400/600", alt: "Nature" },
];
---

<BaseLayout pageTitle={'Work'}>
    <div class="work-container">
        <!--  1. 网站作品集  -->
        <section class="website-portfolio">
            <div class="section-header">
                <h2 class="section-title">Web Portfolio</h2>
            </div>
            <div class="website-grid">
                {websiteWorks.map(work => (
                    <WorkCard {...work} />
                ))}
            </div>
        </section>

        <!--  2. 摄影作品集  -->
        <section class="photo-portfolio">
            <div class="section-header">
                <h2 class="section-title">Photography Album</h2>
                <div class="photo-controls">
                    <button id="scatter-btn" class="retro-btn">Scatter Photos</button>
                    <button id="flip-btn" class="retro-btn">Next Photo</button>
                </div>
            </div>
            <div class="album-container" id="photo-album">
                {photoWorks.map((photo, index) => (
                    <div class="photo-item" style={`--index: ${index}; --total: ${photoWorks.length};`}>
                        <div class="photo-inner">
                            <img src={photo.src} alt={photo.alt} loading="lazy" />
                        </div>
                    </div>
                ))}
            </div>
        </section>
    </div>
</BaseLayout>

<script>
    const album = document.getElementById('photo-album');
    const scatterBtn = document.getElementById('scatter-btn');
    const flipBtn = document.getElementById('flip-btn');
    
    let isScattered = false;
    let currentIndex = 0;
    const totalPhotos = 6; // Matching photoWorks.length

    function updateAlbum() {
        const photos = document.querySelectorAll('.photo-item');
        photos.forEach((photo, index) => {
            const el = photo as HTMLElement;
            if (isScattered) {
                // Scatter logic - stay scattered
                return;
            }
            
            // Stack logic
            const relativeIndex = (index - currentIndex + totalPhotos) % totalPhotos;
            el.style.zIndex = (totalPhotos - relativeIndex).toString();
            
            if (relativeIndex === 0) {
                el.style.transform = 'rotate(0deg) translate(0, 0)';
                el.style.opacity = '1';
            } else {
                const rotate = (relativeIndex * 2);
                const offset = (relativeIndex * 4);
                el.style.transform = `rotate(${rotate}deg) translate(${offset}px, ${offset}px)`;
                el.style.opacity = relativeIndex > 3 ? '0' : '1';
            }
        });
    }

    scatterBtn?.addEventListener('click', () => {
        isScattered = !isScattered;
        const photos = document.querySelectorAll('.photo-item');
        scatterBtn.textContent = isScattered ? 'Stack Photos' : 'Scatter Photos';
        
        if (flipBtn) (flipBtn as HTMLButtonElement).disabled = isScattered;

        photos.forEach((photo, index) => {
            const el = photo as HTMLElement;
            if (isScattered) {
                const angle = Math.random() * 40 - 20;
                const x = (Math.random() - 0.5) * (window.innerWidth * 0.6);
                const y = (Math.random() - 0.5) * 400;
                el.style.transform = `translate(${x}px, ${y}px) rotate(${angle}deg)`;
                el.style.zIndex = (100 + index).toString();
                el.style.opacity = '1';
            } else {
                updateAlbum();
            }
        });
    });

    flipBtn?.addEventListener('click', () => {
        if (isScattered) return;
        
        const photos = document.querySelectorAll('.photo-item');
        const currentPhoto = photos[currentIndex] as HTMLElement;
        
        // Animation for flipping
        currentPhoto.style.transform = 'translateX(-120%) rotate(-20deg)';
        currentPhoto.style.opacity = '0';
        
        setTimeout(() => {
            currentIndex = (currentIndex + 1) % totalPhotos;
            updateAlbum();
        }, 300);
    });

    // Initial state
    updateAlbum();
</script>

<style lang="scss">
    @use '../styles/_mixins.scss' as *;

    .work-container {
        grid-column: 1 / 25;
        display: flex;
        flex-direction: column;
        gap: 64px;
        padding-top: 36px;
        padding-bottom: 100px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
      
        margin-bottom: 24px;
        padding-bottom: 8px;
      
        width: 100%;
      
        border-bottom: 2px solid var(--secondary);
        
    }

    .section-title {
        font-size: 1.5rem;
        color: var(--primary);
        margin: 0;
    }

    .photo-controls {
        display: flex;
        gap: 8px;
    }

    .retro-btn {
        padding: 4px 12px;
        background: var(--gray-bg);
        @include retro-raised;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--gray);
        cursor: pointer;

        &:active:not(:disabled) {
            @include retro-inset;
        }

        &:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
    }

    .website-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 32px;
    }

    .photo-portfolio {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-height: 600px;
    }

    .album-container {
        position: relative;
        width: 320px;
        height: 440px;
        margin-top: 40px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .photo-item {
        position: absolute;
        width: 100%;
        height: 100%;
        transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1), opacity 0.4s, z-index 0s;
        pointer-events: none;
    }

    .photo-inner {
        width: 100%;
        height: 100%;
        background: white;
        padding: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
        pointer-events: auto;

        img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
    }

    @media (max-width: 768px) {
        .website-grid {
            grid-template-columns: 1fr;
        }

        .album-container {
            width: 280px;
            height: 380px;
        }
    }
</style>
