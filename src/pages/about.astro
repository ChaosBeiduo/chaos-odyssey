---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<style lang="scss">
	.chaos-about {
		grid-column: 1 / 25;
		padding-top: 36px;

		a {
			text-decoration: underline;

			&:hover {
				opacity: 0.8;
			}
		}

		&-intro {
			text-align: center;
			font-weight: lighter;

			p {
				margin: unset;
			}

			h1 {
				margin-bottom: unset;
				color: var(--primary);
				font-weight: lighter;

				span {
					font-size: 1.5rem;
				}
			}
		}

		highlight {
			color: var(--primary);
		}

		h3,
		ul,
		p {
			margin: unset;
		}

		h3 {
			margin-top: 36px;
			margin-bottom: 12px;
			color: var(--gray);
			font-size: 1rem;
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.04em;
		}
		// ----- Card grid -----
		&-grid {
			display: grid;
			gap: 16px;
			grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
			align-items: stretch;

			@media (min-width: 900px) {
				grid-template-columns: repeat(3, 1fr);
			}

			@media (min-width: 1200px) {
				grid-template-columns: repeat(3, 1fr);
			}

			@media (max-width: 600px) {
				grid-template-columns: 1fr;
			}
		}

		// ----- Single card -----
		&-card {
			display: flex;
			flex-direction: column;
			min-height: 120px;
			padding: 16px;
			background: var(--gray-bg);
			border: 1px solid var(--gray-border);
			border-radius: 12px;

			&:focus-visible {
				outline: 2px solid var(--primary);
				outline-offset: 2px;
			}

			.chaos-about-card-icon {
				align-self: flex-start;
				margin-bottom: 10px;
				transform: rotate(-2deg);
			}

			.chaos-about-card-title {
				margin: 0 0 4px 0;
				font-size: 1rem;
				font-weight: 600;
				color: var(--gray);
				line-height: 1.3;
			}

			.chaos-about-card-desc {
				margin: 0;
				font-size: 0.875rem;
				color: var(--gray);
				line-height: 1.45;
				flex: 1;
			}
		}

		// ----- Hobby card with badge -----
		&-card-badge {
			display: inline-block;
			margin-top: 6px;
			padding: 2px 8px;
			width: fit-content;
			font-size: 0.7rem;
			color: var(--primary);
			background: var(--secondary);
			border-radius: 999px;
			border: 1px solid var(--border);
		}

		// ----- Chips (skills, hobbies) -----
		&-chips {
			display: flex;
			flex-wrap: wrap;
			gap: 8px;
			margin-top: 8px;
		}

		&-chip {
			padding: 4px 10px;
			font-size: 0.8rem;
			color: var(--primary);
			background: var(--secondary);
			border: 1px solid var(--border);
			border-radius: 999px;
		}

		// ----- Language pills -----
		&-lang-pills {
			display: flex;
			flex-wrap: wrap;
			gap: 8px;
			margin-top: 12px;
		}

		&-lang-pill {
			padding: 6px 14px;
			font-size: 0.875rem;
			font-weight: 500;
			color: var(--primary);
			background: var(--secondary);
			border: 1px solid var(--border);
			border-radius: 999px;
		}

		// ----- Sticky note (French) -----
		&-sticky-note {
			position: relative;
			margin-top: 16px;
			max-width: 360px;
			padding: 14px 18px 18px 18px;
			background: var(--secondary);
			border: 1px solid var(--border);
			border-radius: 4px;
			font-size: 0.875rem;
			color: var(--gray);

			&::before {
				content: "";
				position: absolute;
				top: 0;
				right: 0;
				width: 0;
				height: 0;
				border-style: solid;
				border-width: 0 20px 20px 0;
				border-color: transparent color-mix(in oklch, var(--gray-border) 85%, var(--gray-bg)) transparent transparent;
			}

			&::after {
				content: "";
				position: absolute;
				top: 0;
				right: 0;
				width: 0;
				height: 0;
				border-style: solid;
				border-width: 0 18px 18px 0;
				border-color: transparent var(--secondary) transparent transparent;
			}
		}

		// ----- Icon wrapper (consistent size) -----
		&-icon-wrap {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 40px;
			height: 40px;
			border-radius: 10px;
			background: var(--secondary);
			border: 1px solid var(--border);
			color: var(--primary);
		}

		&-icon-wrap svg {
			width: 24px;
			height: 24px;
			fill: currentColor;
			object-fit: contain;
		}

		&-icon-wrap svg[viewBox="0 0 24 16"] {
			width: 28px;
			height: 20px;
		}
	}
</style>

<BaseLayout pageTitle={'About Me'}>
