---
const currentPath = Astro.url.pathname;

const showProgressBar = currentPath.includes('/posts/');

const isActive = (href: string) => {
    if (currentPath === href) {
        return 'active';
    }
    return '';
};

// Get current URL for address bar
const currentUrl = Astro.url.pathname === '/' 
	? 'https://chaosland/' 
	: `https://chaosland${Astro.url.pathname}`;
---

<header class="chaos-header">
	<div class="chaos-browser-window">
		<!-- Title bar -->
		<div class="chaos-browser-titlebar">
			<div class="chaos-browser-titlebar-title">
                <i class="fa-brands fa-edge-legacy"></i>
				<span>CHAOSLAND</span>
			</div>
			<div class="chaos-browser-titlebar-buttons">
				<button class="chaos-browser-titlebar-button" aria-label="Minimize" title="Minimize">_</button>
				<button class="chaos-browser-titlebar-button" aria-label="Maximize" title="Maximize">□</button>
				<button class="chaos-browser-titlebar-button" aria-label="Close" title="Close">×</button>
			</div>
		</div>

		<!-- Toolbar -->
		<div class="chaos-browser-toolbar">
			<button class="chaos-browser-button" disabled aria-label="Back"><i class="fa-solid fa-angle-left"></i> Back</button>
			<button class="chaos-browser-button" disabled aria-label="Forward">Forward <i class="fa-solid fa-angle-right"></i></button>
			<button class="chaos-browser-button" disabled aria-label="Refresh"><i class="fa-solid fa-rotate-right"></i> Refresh</button>
			<a class={`chaos-browser-button ${isActive('/')}`} aria-label="Home" href="/">
				<i class="fa-solid fa-house"></i> Home
            </a>
            <a class={`chaos-browser-button ${isActive('/about/')}`} aria-label="About me" href="/about/">
				<i class="fa-regular fa-face-meh"></i> About me
            </a>
		</div>

		<!-- Address bar -->
		<div class="chaos-browser-addressbar">
			<span class="chaos-browser-address-label"><i class="fa-solid fa-circle-info"></i></span>
			<input 
				type="text" 
				class="chaos-browser-address-input" 
				value={currentUrl}
				readonly
				aria-label="Address bar"
			/>
		</div>
	</div>

	{showProgressBar && (
		<div class="progress-container">
			<div class="progress-bar"></div>
		</div>
	)}
</header>

<style lang="scss">
	// Retro Windows 98 beveled border helpers
	@mixin retro-raised {
		border-style: solid;
		border-width: 1px;
		border-top-color: color-mix(in oklch, var(--gray-bg) 100%, white);
		border-left-color: color-mix(in oklch, var(--gray-bg) 100%, white);
		border-bottom-color: color-mix(in oklch, var(--gray) 30%, black);
		border-right-color: color-mix(in oklch, var(--gray) 30%, black);
	}

	@mixin retro-inset {
		border-style: solid;
		border-width: 1px;
		border-top-color: color-mix(in oklch, var(--gray) 30%, black);
		border-left-color: color-mix(in oklch, var(--gray) 30%, black);
		border-bottom-color: color-mix(in oklch, var(--gray-bg) 100%, white);
		border-right-color: color-mix(in oklch, var(--gray-bg) 100%, white);
	}

	.chaos-header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 1000;
		width: 100%;
		font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", "Tahoma", "Verdana", sans-serif;

		@keyframes grow-progress {
			from { transform: scaleX(0); }
			to { transform: scaleX(1); }
		}

		.progress-container {
			position: absolute;
			bottom: 0;
			left: 0;
			width: 100%;
			height: 4px;
			background: var(--secondary);
			overflow: hidden;
		}

		.progress-bar {
			width: 100%;
			height: 100%;
			background: var(--primary);
			background-size: 35px 100%;
			transform-origin: left;
			animation: grow-progress auto linear forwards;
			animation-timeline: scroll(root), auto;
		}
	}

	.chaos-browser-window {
		display: flex;
		flex-direction: column;
		background: var(--gray-bg);
		@include retro-raised;
		border-width: 2px;
		width: 100%;
		max-width: 100vw;
	}

	.chaos-browser-titlebar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 4px 6px;
		background: linear-gradient(
			to bottom,
			color-mix(in oklch, var(--primary) 15%, white),
			color-mix(in oklch, var(--primary) 8%, white)
		);
		border-bottom: 1px solid color-mix(in oklch, var(--gray) 20%, black);
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--gray);
		min-height: 22px;

		&-title {
			display: flex;
			align-items: center;
			gap: 6px;
			flex: 1;

			svg {
				width: 14px;
				height: 14px;
				color: var(--primary);
			}
		}

		&-buttons {
			display: flex;
			gap: 2px;
		}

		&-button {
			width: 16px;
			height: 14px;
			padding: 0;
			border: none;
			background: var(--gray-bg);
			@include retro-raised;
			cursor: pointer;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 10px;
			color: var(--gray);
			line-height: 1;

			&:active {
				@include retro-inset;
			}

			&:hover {
				background: color-mix(in oklch, var(--gray-bg) 90%, var(--primary));
			}
		}
	}

	.chaos-browser-toolbar {
		display: flex;
		align-items: center;
		gap: 2px;
		padding: 4px 6px;
		background: var(--gray-bg);
		border-bottom: 1px solid color-mix(in oklch, var(--gray-border) 80%, black);
	}

	.chaos-browser-button {
		padding: 3px 8px;
		font-size: 0.6875rem;
		font-weight: 600;
		color: var(--gray);
		background: var(--gray-bg);
		@include retro-raised;
		border: none;
		cursor: pointer;
		white-space: nowrap;

		&:disabled {
			@include retro-inset;
			opacity: 0.5;
			cursor: not-allowed;
		}

		&:not(:disabled):hover {
			background: color-mix(in oklch, var(--gray-bg) 95%, var(--primary));
		}

		&:not(:disabled):active, &.active {
			@include retro-inset;
		}
	}

	.chaos-browser-addressbar {
		display: flex;
		align-items: center;
		gap: 4px;
		padding: 4px 6px;
		background: white;
		border-bottom: 1px solid color-mix(in oklch, var(--gray-border) 80%, black);
	}

	.chaos-browser-address-label {
		font-size: 0.6875rem;
		font-weight: 600;
		color: var(--gray);
		white-space: nowrap;
	}

	.chaos-browser-address-input {
		flex: 1;
		padding: 2px 6px;
		font-size: 0.75rem;
		font-family: "Courier New", monospace;
		color: var(--gray);
		background: white;
		@include retro-inset;
		border: none;
		outline: none;
		min-width: 0;

		&:focus {
			outline: 1px dashed var(--primary);
			outline-offset: -1px;
		}
	}

	@media (max-width: 768px) {
		.chaos-browser-titlebar {
			font-size: 0.6875rem;
			padding: 3px 4px;
			min-height: 20px;

			&-title svg {
				width: 12px;
				height: 12px;
			}
		}

		.chaos-browser-toolbar {
			padding: 3px 4px;
			flex-wrap: wrap;
		}

		.chaos-browser-button {
			padding: 2px 6px;
			font-size: 0.625rem;
		}

		.chaos-browser-addressbar {
			padding: 3px 4px;
		}

		.chaos-browser-address-label {
			font-size: 0.625rem;
		}

		.chaos-browser-address-input {
			font-size: 0.6875rem;
		}
	}
</style>
