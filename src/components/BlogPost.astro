---
const { post } = Astro.props;
const frontmatter = post.frontmatter;

// Extract preview snippet
const preview = frontmatter.description || '';
const previewLength = 160;
const snippet = preview.length > previewLength 
	? preview.slice(0, previewLength).trim() + '...' 
	: preview;

// Format date
const pubDate = frontmatter.pubDate 
	? new Date(frontmatter.pubDate).toLocaleDateString('en-US', { 
		year: 'numeric', 
		month: 'short', 
		day: 'numeric' 
	})
	: '';

// Check if post is new (within last 7 days)
const isNew = frontmatter.pubDate 
	? (Date.now() - new Date(frontmatter.pubDate).getTime()) < 7 * 24 * 60 * 60 * 1000
	: false;
---

<article class="blog-post-item">
	<div class="post-header">
		<h3 class="post-title">
			<a href={post.url}>{frontmatter.title}</a>
			{isNew && <span class="new-badge">NEW</span>}
		</h3>
		<time class="post-date" datetime={frontmatter.pubDate?.toString() || ''}>
			{pubDate}
		</time>
	</div>
	{snippet && <p class="post-snippet">{snippet}</p>}
</article>

<style lang="scss">
	.blog-post-item {
		padding: 24px 0;
		border-bottom: 1px solid var(--gray-border);
		transition: transform 0.2s ease;

		&:last-child {
			border-bottom: none;
		}

		&:hover {
			.post-title a {
				color: var(--primary);
			}
		}
	}

	.post-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 16px;
		margin-bottom: 8px;

		@media (max-width: 640px) {
			flex-direction: column;
			gap: 4px;
		}
	}

	.post-title {
		margin: 0;
		font-size: 1.25rem;
		font-weight: 600;
		line-height: 1.4;

		a {
			color: #000;
			text-decoration: none;
			transition: color 0.2s ease;

			&:hover {
				text-decoration: underline;
				text-decoration-color: var(--border);
				text-underline-offset: 4px;
			}
		}
	}

	.new-badge {
		display: inline-block;
		margin-left: 8px;
		padding: 2px 6px;
		font-size: 0.75rem;
		font-weight: 700;
		color: #fff;
		background: var(--primary);
		border-radius: 4px;
		vertical-align: middle;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.post-date {
		font-size: 0.875rem;
		color: var(--gray);
		opacity: 0.8;
		white-space: nowrap;
	}

	.post-snippet {
		margin: 0;
		font-size: 1rem;
		color: var(--gray);
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
