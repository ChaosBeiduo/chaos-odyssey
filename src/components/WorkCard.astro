---
const { title, description, image, url, technologies } = Astro.props;
---

<div class="work-card">
    <div class="work-card-titlebar">
        <div class="work-card-titlebar-title">
            <i class="fa-solid fa-window-maximize"></i>
            <span>{title}</span>
        </div>
        <div class="work-card-titlebar-buttons">
            <button class="work-card-button" aria-label="Minimize">_</button>
            <button class="work-card-button" aria-label="Maximize">□</button>
            <button class="work-card-button" aria-label="Close">×</button>
        </div>
    </div>
    
    <div class="work-card-toolbar">
        <div class="work-card-address">
            <span><i class="fa-solid fa-circle-info"></i></span>
            <div class="work-card-address-input">
                {url || 'https://chaosland/work'}
            </div>
        </div>
    </div>

    <div class="work-card-content">
        {image && <div class="work-card-image"><img src={image} alt={title} /></div>}
        <div class="work-card-info">
            <h3 class="work-card-heading">{title}</h3>
            <p class="work-card-description">{description}</p>
            {technologies && (
                <div class="work-card-tags">
                    {technologies.map((tech: string) => (
                        <span class="work-card-tag">{tech}</span>
                    ))}
                </div>
            )}
            {url && (
                <div class="work-card-actions">
                    <a href={url} target="_blank" rel="noopener noreferrer" class="work-card-link-button">
                        Visit Site
                    </a>
                </div>
            )}
        </div>
    </div>
</div>

<style lang="scss">
    @use '../styles/_mixins.scss' as *;

    .work-card {
        background: var(--gray-bg);
        @include retro-raised;
        border-width: 2px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;

        &:hover {
            transform: translateY(-4px);
            box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.1);
        }

        &-titlebar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 2px 4px;
            background: linear-gradient(
                to bottom,
                color-mix(in oklch, var(--primary) 10%, white),
                color-mix(in oklch, var(--primary) 5%, white)
            );
            border-bottom: 1px solid color-mix(in oklch, var(--gray) 20%, black);
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--gray);
            min-height: 20px;

            &-title {
                display: flex;
                align-items: center;
                gap: 4px;
                overflow: hidden;
                white-space: nowrap;
                text-overflow: ellipsis;

                svg, i {
                    font-size: 10px;
                    color: var(--primary);
                }
            }

            &-buttons {
                display: flex;
                gap: 2px;
            }
        }

        &-button {
            width: 14px;
            height: 12px;
            padding: 0;
            border: none;
            background: var(--gray-bg);
            @include retro-raised;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 8px;
            color: var(--gray);
            line-height: 1;

            &:active {
                @include retro-inset;
            }
        }

        &-toolbar {
            padding: 4px;
            background: var(--gray-bg);
            border-bottom: 1px solid color-mix(in oklch, var(--gray-border) 80%, black);
        }

        &-address {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.65rem;
            color: var(--gray);

            &-input {
                flex: 1;
                background: white;
                @include retro-inset;
                padding: 1px 4px;
                font-family: "Courier New", monospace;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }
        }

        &-content {
            padding: 12px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        &-image {
            @include retro-inset;
            aspect-ratio: 16 / 9;
            overflow: hidden;
            background: #eee;

            img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }
        }

        &-info {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        &-heading {
            margin: 0;
            font-size: 1rem;
            color: var(--primary);
        }

        &-description {
            margin: 0;
            font-size: 0.875rem;
            color: var(--gray);
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        &-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
        }

        &-tag {
            font-size: 0.625rem;
            padding: 2px 6px;
            background: var(--secondary);
            color: var(--primary);
            border-radius: 4px;
        }

        &-actions {
            margin-top: auto;
            padding-top: 8px;
        }

        &-link-button {
            display: inline-block;
            padding: 4px 12px;
            background: var(--gray-bg);
            @include retro-raised;
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--gray);
            text-align: center;

            &:active {
                @include retro-inset;
            }

            &:hover {
                background: color-mix(in oklch, var(--gray-bg) 90%, var(--primary));
            }
        }
    }
</style>
