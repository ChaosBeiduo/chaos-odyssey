---
const { title, description, image, url, repoUrl, technologies } = Astro.props;
---

<div class="work-card">
    <div class="work-card-inner">
        {image && (
            <div class="work-card-image">
                <img src={image} alt={title} loading="lazy" />
            </div>
        )}
        
        <div class="work-card-content">
            <div class="work-card-main">
                <div class="work-card-header">
                    <div class="work-card-title-row flex">
                        <h3 class="work-card-title">{title}</h3>
                        {repoUrl && (
                            <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="work-card-repo-link" title="View Source Code">
                                <i class="fa-brands fa-github"></i>
                            </a>
                        )}
                    </div>
                    {technologies && (
                        <div class="work-card-tags">
                            {technologies.map((tech: string) => (
                                <span class="work-card-tag">{tech}</span>
                            ))}
                        </div>
                    )}
                </div>
                <p class="work-card-description">{description}</p>
            </div>

            {url && (
                <div class="work-card-footer">
                    <a href={url} target="_blank" rel="noopener noreferrer" class="work-card-button">
                        Visit DEMO<i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
            )}
        </div>
    </div>
</div>

<style lang="scss">
    .work-card {
        background: white;
        border: 1px solid var(--gray-border);
        height: 100%;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        display: flex;
        flex-direction: column;

        &:hover {
            border-color: var(--primary);
            box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.05);

            .work-card-button {
                background: var(--primary);
                color: white;
                
                i {
                    transform: translateX(3px);
                }
            }
        }

        &-inner {
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        &-image {
            width: 100%;
            aspect-ratio: 16 / 9;
            overflow: hidden;
            background: var(--gray-bg);
            border-bottom: 1px solid var(--gray-border);

            img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
            }
        }

        &-content {
            padding: 24px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
            gap: 20px;
        }

        &-main {
            flex-grow: 1;
        }

        &-header {
            margin-bottom: 12px;
        }

        &-title-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 8px;
        }

        &-title {
            margin: 0;
            font-size: 1.35rem;
            font-weight: 700;
            color: #111;
            letter-spacing: -0.01em;
            line-height: 1.2;
        }

        &-repo-link {
            font-size: 1.5rem;
            color: var(--gray);
            transition: all 0.3s ease;
            line-height: 1;
            margin-top: 2px;

            &:hover {
                color: var(--primary);
                transform: translateY(-2px);
            }
        }

        &-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        &-tag {
            font-size: 0.7rem;
            color: var(--gray);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            background: var(--gray-bg);
            padding: 2px 8px;
            border-radius: 2px;
        }

        &-description {
            margin: 0;
            font-size: 0.95rem;
            line-height: 1.6;
            color: var(--gray);
            font-weight: 400;
        }

        &-footer {
            margin-top: auto;
            padding-top: 8px;
        }

        &-work-link {
          text-decoration: none;
        }

        &-button {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 10px 20px;
            border: 1.5px solid var(--primary);
            color: var(--primary);
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            text-decoration: none;
            transition: all 0.3s ease;

            i {
                transition: transform 0.3s ease;
            }
        }
    }

    @media (max-width: 640px) {
        .work-card-content {
            padding: 20px;
        }
        
        .work-card-title {
            font-size: 1.2rem;
        }
    }
</style>
