---
import BaseLayout from "./BaseLayout.astro";
const { frontmatter, headings } = Astro.props;
---

<style lang="scss">
  .chaos-post{
    margin-top: 36px;
  }

  .chaos-table-header{
    border-bottom: 1px dashed lightgray;

    &-label{
      display: flex;
      gap: 3px;
    }
  }

  @media (max-width: 768px) {
    .chaos-post {
      display: flex;
      flex-direction: column;
      gap: 24px; 
    }

    .chaos-post-sidebar,
    .chaos-post-content {
      grid-column: 1 / -1;
      width: 100%;
      display: block;
      position: static;
    }

    .chaos-post-sidebar-metadata > div {
      display: flex;
      justify-content: space-between;

      span:first-child {
        flex-shrink: 0;
      }
    }
  }
</style>

<BaseLayout pageTitle={frontmatter.title}>
    <div>
        <div class="text-center">
            <p class="text-gray-500">{frontmatter.pubDate.toString().slice(0, 10)}</p>
            <h1 class="font-light text-4xl">{frontmatter.title}</h1>
            <p class="text-gray-500">{frontmatter.description}</p>
        </div>
        <main class="chaos-post">
            <div class="chaos-markdown">
                <slot/>
            </div>
        </main>
    </div>
</BaseLayout>

<script>
    function setupScrollSpy() {
        const observerOptions = {
            root: null,
            rootMargin: '-10% 0px -80% 0px',
            threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    const id = entry.target.getAttribute('id');
                    if (!id) return;

                    document.querySelectorAll('.chaos-post-sidebar-toc li').forEach((li) => {
                        li.classList.remove('active');
                    });

                    const activeLink = document.querySelector(`.chaos-post-sidebar-toc a[href="#${id}"]`);
                    if (activeLink) {
                        activeLink.parentElement?.classList.add('active');
                    }
                }
            });
        }, observerOptions);

        const headings = document.querySelectorAll('.chaos-markdown h1, .chaos-markdown h2, .chaos-markdown h3');
        headings.forEach((h) => observer.observe(h));
    }

    document.addEventListener('astro:page-load', setupScrollSpy);
    setupScrollSpy();
</script>
